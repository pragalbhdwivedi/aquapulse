AQUAPULSE_PERSISTENCE_MODE=in-memory
AQUAPULSE_ENABLE_POSTGRES_ADAPTERS=false
AQUAPULSE_DB_HEALTHCHECK_ON_BOOT=false

# Web runtime defaults stay mock/in-memory.
NEXT_PUBLIC_AQUAPULSE_WEB_CLIENT_MODE=mock
NEXT_PUBLIC_AQUAPULSE_WEB_ENABLE_PLACEHOLDER_HTTP=false
NEXT_PUBLIC_AQUAPULSE_WEB_ENABLE_FETCH_HTTP=false
NEXT_PUBLIC_AQUAPULSE_WEB_HTTP_BASE_URL=
NEXT_PUBLIC_AQUAPULSE_WEB_ALERTS_MODE=inherit
NEXT_PUBLIC_AQUAPULSE_WEB_ALERTS_HTTP_TRANSPORT=proxy
NEXT_PUBLIC_AQUAPULSE_WEB_ALERTS_HTTP_BASE_URL=
NEXT_PUBLIC_AQUAPULSE_WEB_ENABLE_RUNTIME_PROBES=false

# Web local proxy target for the alerts-only HTTP bridge.
AQUAPULSE_WEB_LOCAL_API_BACKEND_URL=http://localhost:4000
AQUAPULSE_WEB_ENABLE_RUNTIME_PROBES=false
AQUAPULSE_WEB_RUNTIME_PROBE_TIMEOUT_MS=1500

# Optional bounded alerts runtime verification.
AQUAPULSE_ALERTS_VERIFY_WEB_BASE_URL=http://localhost:3000
AQUAPULSE_ALERTS_VERIFY_API_BASE_URL=http://localhost:4000
AQUAPULSE_ALERTS_VERIFY_EXPECT_BACKEND_ADAPTER=postgres
AQUAPULSE_ALERTS_VERIFY_ALERT_ID=alert-1
AQUAPULSE_ALERTS_VERIFY_ENABLE_MUTATIONS=false

# Advisory AI explanations stay on deterministic fallback unless explicitly enabled.
AQUAPULSE_AI_ALERT_EXPLANATIONS_MODE=fallback
OPENAI_ALERT_EXPLANATIONS_MODEL=gpt-5-nano
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

DATABASE_DIALECT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aquapulse
DATABASE_SCHEMA=public
DATABASE_USER=aquapulse
DATABASE_PASSWORD=change-me
DATABASE_SSL_MODE=prefer
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10
DATABASE_APP_NAME=aquapulse-api
