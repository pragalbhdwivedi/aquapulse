AQUAPULSE_PERSISTENCE_MODE=in-memory
AQUAPULSE_ENABLE_POSTGRES_ADAPTERS=false
AQUAPULSE_DB_HEALTHCHECK_ON_BOOT=false

# Web runtime defaults stay mock/in-memory.
NEXT_PUBLIC_AQUAPULSE_WEB_CLIENT_MODE=mock
NEXT_PUBLIC_AQUAPULSE_WEB_ENABLE_PLACEHOLDER_HTTP=false
NEXT_PUBLIC_AQUAPULSE_WEB_ENABLE_FETCH_HTTP=false
NEXT_PUBLIC_AQUAPULSE_WEB_HTTP_BASE_URL=
NEXT_PUBLIC_AQUAPULSE_WEB_AUTH_MODE=disabled
NEXT_PUBLIC_AQUAPULSE_WEB_KEYCLOAK_ISSUER_URL=
NEXT_PUBLIC_AQUAPULSE_WEB_KEYCLOAK_REALM=
NEXT_PUBLIC_AQUAPULSE_WEB_KEYCLOAK_CLIENT_ID=
NEXT_PUBLIC_AQUAPULSE_WEB_LOCAL_AUTH_USER_LABEL=Local Operator
NEXT_PUBLIC_AQUAPULSE_WEB_ALERTS_MODE=inherit
NEXT_PUBLIC_AQUAPULSE_WEB_ALERTS_HTTP_TRANSPORT=proxy
NEXT_PUBLIC_AQUAPULSE_WEB_ALERTS_HTTP_BASE_URL=
NEXT_PUBLIC_AQUAPULSE_WEB_ALERTS_LIVE_UPDATES=false
NEXT_PUBLIC_AQUAPULSE_WEB_ALERTS_WS_BASE_URL=
NEXT_PUBLIC_AQUAPULSE_WEB_FEED_MODE=inherit
NEXT_PUBLIC_AQUAPULSE_WEB_FEED_HTTP_TRANSPORT=proxy
NEXT_PUBLIC_AQUAPULSE_WEB_FEED_HTTP_BASE_URL=
NEXT_PUBLIC_AQUAPULSE_WEB_TASKS_MODE=inherit
NEXT_PUBLIC_AQUAPULSE_WEB_TASKS_HTTP_TRANSPORT=proxy
NEXT_PUBLIC_AQUAPULSE_WEB_TASKS_HTTP_BASE_URL=
NEXT_PUBLIC_AQUAPULSE_WEB_WATER_QUALITY_MODE=inherit
NEXT_PUBLIC_AQUAPULSE_WEB_WATER_QUALITY_HTTP_TRANSPORT=proxy
NEXT_PUBLIC_AQUAPULSE_WEB_WATER_QUALITY_HTTP_BASE_URL=
NEXT_PUBLIC_AQUAPULSE_WEB_ENABLE_RUNTIME_PROBES=false

# Web local proxy target for the alerts/feed/water-quality HTTP bridges.
AQUAPULSE_WEB_LOCAL_API_BACKEND_URL=http://localhost:4000
AQUAPULSE_WEB_AUTH_BEARER_TOKEN=
AQUAPULSE_WEB_AUTH_TOKEN_COOKIE_NAME=aquapulse_auth_token
AQUAPULSE_WEB_ENABLE_BACKEND_CURRENT_SESSION=false
AQUAPULSE_WEB_CURRENT_SESSION_TIMEOUT_MS=1200
AQUAPULSE_WEB_ENABLE_RUNTIME_PROBES=false
AQUAPULSE_WEB_RUNTIME_PROBE_TIMEOUT_MS=1500

# Auth defaults stay disabled unless explicitly enabled.
AQUAPULSE_AUTH_MODE=disabled
AQUAPULSE_KEYCLOAK_ISSUER_URL=
AQUAPULSE_KEYCLOAK_JWKS_URL=
AQUAPULSE_KEYCLOAK_REALM=
AQUAPULSE_KEYCLOAK_CLIENT_ID=
AQUAPULSE_KEYCLOAK_AUDIENCE=
AQUAPULSE_AUTH_LOCAL_USER_ID=local-operator
AQUAPULSE_AUTH_LOCAL_USERNAME=local.operator
AQUAPULSE_AUTH_LOCAL_DISPLAY_NAME=Local Operator
AQUAPULSE_AUTH_LOCAL_ROLES=operator
AQUAPULSE_AUTH_LOCAL_PERMISSIONS=

# Optional alerts websocket gateway for bounded local live updates.
AQUAPULSE_ENABLE_ALERTS_LIVE_UPDATES=false
AQUAPULSE_ALERTS_LIVE_UPDATES_PATH=/ws/alerts

# Optional bounded alerts runtime verification.
AQUAPULSE_ALERTS_VERIFY_WEB_BASE_URL=http://localhost:3000
AQUAPULSE_ALERTS_VERIFY_API_BASE_URL=http://localhost:4000
AQUAPULSE_ALERTS_VERIFY_EXPECT_BACKEND_ADAPTER=postgres
AQUAPULSE_ALERTS_VERIFY_ALERT_ID=alert-1
AQUAPULSE_ALERTS_VERIFY_ENABLE_MUTATIONS=false
AQUAPULSE_ALERTS_VERIFY_EXPECT_SEEDED_SMOKE=false

# Optional bounded auth/runtime verification.
AQUAPULSE_AUTH_VERIFY_WEB_BASE_URL=http://localhost:3000
AQUAPULSE_AUTH_VERIFY_API_BASE_URL=http://localhost:4000
AQUAPULSE_AUTH_VERIFY_EXPECT_AUTH_MODE=auto
AQUAPULSE_AUTH_VERIFY_BEARER_TOKEN=
AQUAPULSE_AUTH_VERIFY_ALERT_ID=alert-1
AQUAPULSE_AUTH_VERIFY_OWNER=operator-verification
AQUAPULSE_AUTH_VERIFY_ENABLE_MUTATIONS=false

# Optional bounded water-quality runtime verification.
AQUAPULSE_WATER_QUALITY_VERIFY_WEB_BASE_URL=http://localhost:3000
AQUAPULSE_WATER_QUALITY_VERIFY_API_BASE_URL=http://localhost:4000
AQUAPULSE_WATER_QUALITY_VERIFY_EXPECT_BACKEND_ADAPTER=postgres
AQUAPULSE_WATER_QUALITY_VERIFY_POND_ID=pond-1
AQUAPULSE_WATER_QUALITY_VERIFY_READING_ID=wq-smoke-pond-1-latest
AQUAPULSE_WATER_QUALITY_VERIFY_EXPECT_SEEDED_SMOKE=false

# Optional bounded feed runtime verification.
AQUAPULSE_FEED_VERIFY_WEB_BASE_URL=http://localhost:3000
AQUAPULSE_FEED_VERIFY_API_BASE_URL=http://localhost:4000
AQUAPULSE_FEED_VERIFY_EXPECT_BACKEND_ADAPTER=postgres
AQUAPULSE_FEED_VERIFY_POND_ID=pond-1
AQUAPULSE_FEED_VERIFY_ENTRY_ID=feed-1
AQUAPULSE_FEED_VERIFY_EXPECT_SEEDED_SMOKE=false

# Optional bounded tasks runtime verification.
AQUAPULSE_TASKS_VERIFY_WEB_BASE_URL=http://localhost:3000
AQUAPULSE_TASKS_VERIFY_API_BASE_URL=http://localhost:4000
AQUAPULSE_TASKS_VERIFY_EXPECT_BACKEND_ADAPTER=postgres
AQUAPULSE_TASKS_VERIFY_TASK_ID=task-1
AQUAPULSE_TASKS_VERIFY_POND_ID=pond-1
AQUAPULSE_TASKS_VERIFY_EXPECT_SEEDED_SMOKE=false

# Optional local feed smoke-stack defaults. This reuses the local smoke Postgres on 54329.
AQUAPULSE_FEED_SMOKE_DB_HOST=localhost
AQUAPULSE_FEED_SMOKE_DB_PORT=54329
AQUAPULSE_FEED_SMOKE_DB_NAME=aquapulse
AQUAPULSE_FEED_SMOKE_DB_USER=aquapulse
AQUAPULSE_FEED_SMOKE_DB_PASSWORD=change-me
AQUAPULSE_FEED_SMOKE_DB_SSL_MODE=disable

# Optional local tasks smoke-stack defaults. This reuses the local smoke Postgres on 54329.
AQUAPULSE_TASKS_SMOKE_DB_HOST=localhost
AQUAPULSE_TASKS_SMOKE_DB_PORT=54329
AQUAPULSE_TASKS_SMOKE_DB_NAME=aquapulse
AQUAPULSE_TASKS_SMOKE_DB_USER=aquapulse
AQUAPULSE_TASKS_SMOKE_DB_PASSWORD=change-me
AQUAPULSE_TASKS_SMOKE_DB_SSL_MODE=disable

# Optional local water-quality smoke-stack defaults. This reuses the local smoke Postgres on 54329.
AQUAPULSE_WATER_QUALITY_SMOKE_DB_HOST=localhost
AQUAPULSE_WATER_QUALITY_SMOKE_DB_PORT=54329
AQUAPULSE_WATER_QUALITY_SMOKE_DB_NAME=aquapulse
AQUAPULSE_WATER_QUALITY_SMOKE_DB_USER=aquapulse
AQUAPULSE_WATER_QUALITY_SMOKE_DB_PASSWORD=change-me
AQUAPULSE_WATER_QUALITY_SMOKE_DB_SSL_MODE=disable

# Optional local alerts smoke-stack defaults. The compose file publishes Postgres on 54329.
AQUAPULSE_ALERTS_SMOKE_DB_HOST=localhost
AQUAPULSE_ALERTS_SMOKE_DB_PORT=54329
AQUAPULSE_ALERTS_SMOKE_DB_NAME=aquapulse
AQUAPULSE_ALERTS_SMOKE_DB_USER=aquapulse
AQUAPULSE_ALERTS_SMOKE_DB_PASSWORD=change-me
AQUAPULSE_ALERTS_SMOKE_DB_SSL_MODE=disable

# Advisory AI explanations stay on deterministic fallback unless explicitly enabled.
AQUAPULSE_AI_ALERT_EXPLANATIONS_MODE=fallback
OPENAI_ALERT_EXPLANATIONS_MODEL=gpt-5-nano
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

DATABASE_DIALECT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aquapulse
DATABASE_SCHEMA=public
DATABASE_USER=aquapulse
DATABASE_PASSWORD=change-me
DATABASE_SSL_MODE=prefer
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10
DATABASE_APP_NAME=aquapulse-api
