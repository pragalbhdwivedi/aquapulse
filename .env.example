# Shared
NODE_ENV=development
LOG_LEVEL=debug

# Web
NEXT_PUBLIC_APP_NAME=AquaPulse
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# API
API_PORT=4000
API_PREFIX=api

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aquapulse

# Worker
WORKER_CONCURRENCY=5

# AI
OPENAI_API_KEY=
AI_DEFAULT_MODEL=gpt-5-mini

