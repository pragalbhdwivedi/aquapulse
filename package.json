{
  "name": "aquapulse",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "typecheck": "corepack pnpm --filter @aquapulse/types typecheck && corepack pnpm --filter @aquapulse/validation typecheck && corepack pnpm --filter @aquapulse/api typecheck && corepack pnpm --filter @aquapulse/web typecheck",
    "test:contracts": "corepack pnpm exec vitest run",
    "alerts:verify-runtime": "node ./scripts/verify-alerts-runtime.mjs",
    "water-quality:verify-runtime": "node ./scripts/verify-water-quality-runtime.mjs",
    "alerts:smoke:db:up": "docker compose -f ./infra/local/alerts-smoke.compose.yaml up -d",
    "alerts:smoke:db:down": "docker compose -f ./infra/local/alerts-smoke.compose.yaml down",
    "alerts:smoke:db:migrate": "corepack pnpm --filter @aquapulse/database db:migrations:apply",
    "alerts:smoke:db:seed": "corepack pnpm --filter @aquapulse/database db:seed:alerts-smoke",
    "alerts:smoke:db:prepare": "corepack pnpm --filter @aquapulse/database db:prepare:alerts-smoke",
    "db:migrations:list": "corepack pnpm --filter @aquapulse/database db:migrations:list",
    "db:migrations:verify": "corepack pnpm --filter @aquapulse/database db:migrations:verify",
    "db:migrations:show": "corepack pnpm --filter @aquapulse/database db:migrations:show"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
