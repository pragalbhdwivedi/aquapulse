{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@aquapulse/types": ["packages/types/src/index.ts"],
      "@aquapulse/validation": ["packages/validation/src/index.ts"],
      "@aquapulse/database": ["packages/database/src/index.ts"],
      "@web/*": ["apps/web/src/*"]
    }
  }
}
